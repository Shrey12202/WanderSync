# WanderSync Master .gitignore

# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/
.pytest_cache/

# Next.js
.next/
out/
build/

# Misc
.DS_Store
*.pem
*.log
Thumbs.db

# Secrets & Environment
.env*
!.env.example
backend/.env
frontend/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Media Uploads
backend/uploads/*
!backend/uploads/.gitkeep
backend/uploads/thumbnails/*
!backend/uploads/thumbnails/.gitkeep

# Data Files
*.db
*.sqlite
*.sqlite3
*.json
!package.json
!package-lock.json
!tsconfig.json
!next.config.ts
!postcss.config.mjs
!components.json