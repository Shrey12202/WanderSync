# ─────────────────────────────────────────────────────────────────────────────
# WorldMap Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL: uses docker-compose postgres
DATABASE_URL=postgresql+asyncpg://worldmap:worldmap_dev_password@localhost:5432/worldmap

# PRODUCTION (Render): Render injects this automatically when you attach a
# Postgres database. It will look like:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Our code auto-converts it to the asyncpg dialect, so just paste it as-is.

# ── CORS ─────────────────────────────────────────────────────────────────────
# LOCAL
CORS_ORIGINS=http://localhost:3000

# PRODUCTION: comma-separated list, e.g.
# CORS_ORIGINS=https://your-app.vercel.app

# ── File storage ─────────────────────────────────────────────────────────────
# LOCAL: relative path inside the backend directory
UPLOAD_DIR=./uploads

# PRODUCTION NOTE: Render's filesystem is ephemeral — files saved here will be
# deleted on each deploy or restart. For persistent media you need Cloudinary
# or Supabase Storage (a future upgrade). For a first deploy to test things
# out, the local filesystem still works but uploads won't survive redeploys.

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=52428800    # 50 MB in bytes
